# Supabase Configuration
# Preferred keys:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional aliases (supported in code):
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for server-side privileged operations (drafts/admin/payments):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional alias:
# SUPABASE_SERVICE_ROLE=your_service_role_key

# Primary admin email (must match the admin user's auth email in Supabase)
ADMIN_EMAIL=admin@yourdomain.com

# OpenAI API Key (required for AI Practice Client feature)
# Get your key from the OpenAI dashboard.
OPENAI_API_KEY=your_openai_api_key

# Paystack (NGN payments)
PAYSTACK_SECRET_KEY=your_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
# Public site URL for emails and Paystack callbacks. Use your real domain in production (Vercel).
# If BASE_URL is unset or still localhost, production uses VERCEL_URL or the incoming request host.
BASE_URL=https://your-domain.example

# Outgoing email (Resend) — required for automated applicant emails
# Get key from Resend and ensure the FROM address is a verified domain.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=hello@yourdomain.com

# Test data reset script (optional)
# CONFIRM=YES
# DRY_RUN=1
# WIPE_REFERENCE_DATA=NO
# RESET_PRESERVE_STAFF=YES
# RESET_ADMIN_EMAIL=admin@yourdomain.com
# RESET_ADMIN_PASSWORD=your_strong_password_if_admin_must_be_created
# RESET_KEEP_AUTH_EMAILS=ops@yourdomain.com
# RESET_CLEAR_STORAGE=YES
